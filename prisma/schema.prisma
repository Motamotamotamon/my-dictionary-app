generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id           Int      @id @default(autoincrement())
  word         String
  meaning      String?
  definition   String?
  partOfSpeech String?
  example      String?
  aiAnalysis   Json?
  createdAt    DateTime @default(now())

  savedItems   SavedItem[]
}
model SavedItem {
  id        Int      @id @default(autoincrement())
  content   String
  type      String
  wordId    Int?
  word      Word?    @relation(fields: [wordId], references: [id])
  createdAt DateTime @default(now())
  book      String? 
  @@unique([wordId, type])
}
model SearchHistory {
  id        Int      @id @default(autoincrement())
  query     String
  mode      String   // "en-ja" | "ja-en" | "en-en"
  createdAt DateTime @default(now())
}


