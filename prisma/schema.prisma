generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id           Int         @id @default(autoincrement())
  word         String
  partOfSpeech String?
  definition   String?
  meaning      String?
  example      String?
  createdAt    DateTime    @default(now())
  aiAnalysis   Json?
  savedItems   SavedItem[]
}

model SavedItem {
  id        Int      @id @default(autoincrement())
  type      String
  content   String
  wordId    Int?
  createdAt DateTime @default(now())
  book      String?
  jp        String?
  meanings  Json?
  phonetic  String?
  word      Word?    @relation(fields: [wordId], references: [id])

  @@unique([wordId, type])
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  query     String
  mode      String
  createdAt DateTime @default(now())
}
